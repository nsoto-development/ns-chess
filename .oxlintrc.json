{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["react", "typescript"],
  "env": {
    "browser": true
  },
  "ignorePatterns": ["design-system/**", "dist/**", "node_modules/**"],
  "rules": {
    "no-restricted-imports": [
      "error",
      {
        "patterns": [
          {
            "group": ["@ds", "@ds/**"],
            "message": "Import DS kit only from src/components/ui/ wrappers (see docs/design/system-integration.md)."
          },
          {
            "group": ["**/design-system/**"],
            "message": "Do not import design-system/ directly — use src/components/ui/ wrappers."
          }
        ]
      }
    ]
  },
  "overrides": [
    {
      "files": ["src/components/ui/**"],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ]
}
