{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["react", "typescript"],
  "env": {
    "browser": true
  },
  "ignorePatterns": ["dist/**", "node_modules/**", "public/engine/**"],
  "rules": {
    "no-restricted-imports": [
      "error",
      {
        "patterns": [
          {
            "group": ["@nsoto/portfolio-ui", "@nsoto/portfolio-ui/**"],
            "message": "Import UI kit only from src/components/ui/ wrappers (see docs/design/system-integration.md)."
          },
          {
            "group": [
              "@nsoto/portfolio-tokens",
              "@nsoto/portfolio-tokens/**"
            ],
            "message": "Import tokens/assets only from src/components/ui/ wrappers or src/index.css (see docs/design/system-integration.md)."
          }
        ]
      }
    ]
  },
  "overrides": [
    {
      "files": ["src/components/ui/**"],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ]
}
